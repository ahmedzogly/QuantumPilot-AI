# Deta Space - QuantumPilot AI Backend - Free No Visa
# Docs: https://deta.space/docs

v: 0
micros:
  - name: quantumpilot-backend
    src: backend
    engine: python3.11
    primary: true
    public: true
    # Run FastAPI on port 8000, Deta will proxy to 8000
    run: uvicorn app.main:app --host 0.0.0.0 --port 8000
    # Env vars set in Deta Space dashboard
    env:
      - name: POSTGRES_HOST
        value: localhost
      - name: REDIS_URL
        value: memory://
      - name: PYTHONPATH
        value: /app

  - name: quantumpilot-frontend
    src: frontend
    engine: nodejs18
    public: true
    run: npm start
    env:
      - name: NEXT_PUBLIC_API_URL
        value: https://quantumpilot-backend.deta.app/api/v1
